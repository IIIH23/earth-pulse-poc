.env
.env.*
!.env.example
__pycache__/
*.pyc
node_modules/
.venv/
venv/
dist/
build/
coverage/
*.log
secrets/
credentials/

.autopilot.lock

# Local Python environments
.venv_autopilot/

# Test / editor artifacts
.pytest_cache/
*.old

# Runtime output (autopilot/codex execution logs)
artifacts/
artifacts/**/*
!artifacts/**/.gitkeep
!artifacts/**/*.json
!artifacts/**/*.md

# External runtime status docs (generated by Codex/Claude Code sessions)
docs/CLAUDE_CODE_RUNTIME_STATUS.md
docs/CODEX_RUNTIME_STATUS.md

# Windows helper scripts (environment-specific, not part of project)
scripts/obsidian-sync.ps1

# GitHub PAT (never commit)
.github_pat

# Local config from external environments
# Agent and tool registries are tracked; other config/ files are ignored.
!config/agent-registry.yaml
!config/tool-registry.yaml
config/*
!config/agent-registry.yaml
!config/tool-registry.yaml
